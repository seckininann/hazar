# ── Cloudinary (fotoğraf depolama — ücretsiz, kart yok)
# cloudinary.com → email kayıt → Dashboard'dan al
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ── Firebase Firestore (veritabanı — ücretsiz Spark planı)
# console.firebase.google.com → Proje Ayarları → Web uygulaması
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
